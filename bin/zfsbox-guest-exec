#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
    SCRIPT_LINK="$(readlink "${SCRIPT_PATH}")"
    if [[ "${SCRIPT_LINK}" != /* ]]; then
        SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_LINK}"
    else
        SCRIPT_PATH="${SCRIPT_LINK}"
    fi
done

BIN_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
PROJECT_DIR="$(cd "${BIN_DIR}/.." && pwd)"

if [[ $# -eq 0 ]]; then
    echo "Usage: $(basename "$0") <command> [args...]" >&2
    exit 1
fi

case "$(uname -s)" in
    Darwin)
        exec "${PROJECT_DIR}/scripts/macos-lima-zfs-exec.sh" "$@"
        ;;
    Linux)
        exec "${PROJECT_DIR}/scripts/linux-qemu-zfs-exec.sh" "$@"
        ;;
    *)
        echo "Unsupported host OS: $(uname -s)" >&2
        exit 1
        ;;
esac
