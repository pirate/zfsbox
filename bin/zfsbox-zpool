#!/usr/bin/env bash
set -Eeuo pipefail

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "${BIN_DIR}/.." && pwd)"

needs_sync=0

case "${1:-}" in
    create|destroy|export|import|rename|split|add|remove|attach|detach|replace|online|offline)
        needs_sync=1
        ;;
esac

set +e
"${BIN_DIR}/zfsbox-guest-exec" zpool "$@"
status=$?
set -e

if [[ "${status}" -eq 0 && "${needs_sync}" -eq 1 ]]; then
    "${PROJECT_DIR}/scripts/reconcile-host-mounts.sh"
fi

exit "${status}"
