#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_PATH="${BASH_SOURCE[0]}"
while [[ -L "${SCRIPT_PATH}" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
    SCRIPT_LINK="$(readlink "${SCRIPT_PATH}")"
    if [[ "${SCRIPT_LINK}" != /* ]]; then
        SCRIPT_PATH="${SCRIPT_DIR}/${SCRIPT_LINK}"
    else
        SCRIPT_PATH="${SCRIPT_LINK}"
    fi
done

BIN_DIR="$(cd "$(dirname "${SCRIPT_PATH}")" && pwd)"
PROJECT_DIR="$(cd "${BIN_DIR}/.." && pwd)"

needs_sync=0

case "${1:-}" in
    create|destroy|rename|clone|receive|recv|set|inherit|mount|unmount|umount|load-key|unload-key)
        needs_sync=1
        ;;
esac

set +e
"${BIN_DIR}/zfsbox-guest-exec" zfs "$@"
status=$?
set -e

if [[ "${status}" -eq 0 && "${needs_sync}" -eq 1 ]]; then
    "${PROJECT_DIR}/scripts/reconcile-host-mounts.sh"
fi

exit "${status}"
