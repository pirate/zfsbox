#!/usr/bin/env bash
set -Eeuo pipefail

exec >/dev/console 2>&1

log() {
    printf 'zfsbox-init: %s\n' "$*"
}

trap 'rc=$?; log "failed at line ${LINENO} with status ${rc}"; exit "${rc}"' ERR

PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export PATH

mountpoint -q /proc || mount -t proc proc /proc
mountpoint -q /sys || mount -t sysfs sysfs /sys
mountpoint -q /dev || mount -t devtmpfs devtmpfs /dev
mkdir -p /dev/pts /run /tmp
mountpoint -q /dev/pts || mount -t devpts devpts /dev/pts
mountpoint -q /run || mount -t tmpfs tmpfs /run
mountpoint -q /tmp || mount -t tmpfs tmpfs /tmp
chmod 1777 /tmp
mkdir -p /dev/zfsbox

for sysdev in /sys/block/vd*; do
    [[ -e "${sysdev}" ]] || continue
    devname="$(basename "${sysdev}")"
    serial=""
    if [[ -r "${sysdev}/device/serial" ]]; then
        serial="$(tr -d '[:space:]' < "${sysdev}/device/serial")"
    elif [[ -r "${sysdev}/serial" ]]; then
        serial="$(tr -d '[:space:]' < "${sysdev}/serial")"
    fi

    case "${serial}" in
        zfsbox-data-*)
            ln -sf "/dev/${devname}" "/dev/zfsbox/${serial}"
            if [[ -b "/dev/${devname}1" ]]; then
                ln -sf "/dev/${devname}1" "/dev/zfsbox/${serial}-part1"
            fi
            ;;
    esac
done

log "mounting core filesystems"
hostname zfsbox || true

netdev="$(ip -o link show | awk -F': ' '$2 != "lo" {print $2; exit}')"
if [[ -n "${netdev}" ]]; then
    log "configuring network on ${netdev}"
    ip link set dev lo up || true
    ip link set dev "${netdev}" up || true
    if ! ip -4 addr show dev "${netdev}" | grep -q '10\.0\.2\.'; then
        ip addr add 10.0.2.15/24 dev "${netdev}" 2>/dev/null || true
    fi
    ip route replace default via 10.0.2.2 dev "${netdev}" 2>/dev/null || true
fi

log "mounting host root"
/usr/local/sbin/zfsbox-mount-hostroot.sh
log "preparing guest control plane"
/usr/local/sbin/zfsbox-guest-init.sh

mkdir -p /run/sshd
ssh-keygen -A >/dev/null 2>&1 || true
log "starting sshd"
/usr/sbin/sshd -D -e &
sshd_pid=$!

for _ in $(seq 1 50); do
    if ss -ltn 2>/dev/null | grep -qE '(^|[[:space:]])LISTEN[[:space:]].*:22[[:space:]]'; then
        break
    fi
    sleep 0.1
done

log "writing ready marker"
/usr/local/sbin/zfsbox-write-ready.sh
log "guest boot complete"

shutdown() {
    kill "${sshd_pid}" 2>/dev/null || true
    wait "${sshd_pid}" 2>/dev/null || true
    sync
    poweroff -f >/dev/null 2>&1 || halt -f >/dev/null 2>&1 || exit 0
}

trap shutdown TERM INT

wait "${sshd_pid}"
exit $?
